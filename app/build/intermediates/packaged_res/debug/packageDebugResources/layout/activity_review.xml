<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="24dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Write a Review" android:textColor="@color/text_brown" android:textSize="24sp" android:textStyle="bold" />
    <RatingBar android:id="@+id/ratingBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:numStars="5" android:rating="5" android:stepSize="1" />
    <EditText android:id="@+id/commentInput" android:layout_width="match_parent" android:layout_height="160dp" android:layout_marginTop="16dp" android:gravity="top" android:hint="Share your experience" />
    <Button android:id="@+id/submitReviewButton" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="20dp" android:backgroundTint="@color/primary_orange" android:text="Submit Review" android:textColor="@color/white" />
</LinearLayout>
